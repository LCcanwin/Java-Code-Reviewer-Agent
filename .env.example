# GitHub API token (required for GitHub PRs)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# GitLab API token (required for GitLab PRs)
GITLAB_TOKEN=glpat-xxxxxxxxxxxx

# Comma-separated repository whitelist (e.g., "org/repo1,org/repo2")
SCOPE_LIMIT=

# LLM Configuration
LLM_PROVIDER=openai  # openai or anthropic
LLM_API_KEY=sk-xxxxxxxxxxxx
LLM_MODEL=gpt-4o

# Optional: Custom LLM base URL for proxies
LLM_BASE_URL=
